{
  "dataset": {
    "name": "kilt_hotpotqa_ivf_live",
    "version": "2026-03-29",
    "source_path": "hf://kilt_tasks/hotpotqa[validation][:10000]"
  },
  "embedding": {
    "model": "BAAI/bge-small-en-v1.5",
    "dimension": 384,
    "normalized": false
  },
  "chunking": {
    "strategy": "question_answer_seed",
    "chunk_size": 1,
    "chunk_overlap": 0
  },
  "schema": {
    "documents_table": "rag_documents",
    "passages_table": "rag_passages"
  },
  "regression_gate": {
    "dataset_id": "kilt_hotpotqa",
    "method_id": "pg_turboquant_approx",
    "recall_at_10_floor": 0.9,
    "max_visited_code_fraction": 0.85,
    "max_visited_page_fraction": 0.6,
    "expected_score_mode": "code_domain",
    "max_effective_probe_count": 8
  },
  "backends": [
    {
      "kind": "pg_turboquant",
      "index_name": "rag_passages_tq_idx",
      "metric": "cosine",
      "mode": "approx",
      "ann": {
        "probes": 8,
        "oversampling": 4,
        "max_visited_codes": 4096,
        "max_visited_pages": 0
      },
      "options": {
        "lists": 64,
        "bits": 4,
        "router_restarts": 3
      }
    },
    {
      "kind": "pgvector_hnsw",
      "index_name": "rag_passages_hnsw_idx",
      "metric": "cosine",
      "mode": "approx",
      "options": {
        "m": 16,
        "ef_construction": 64
      }
    },
    {
      "kind": "pgvector_ivfflat",
      "index_name": "rag_passages_ivf_idx",
      "metric": "cosine",
      "mode": "approx",
      "options": {
        "lists": 64
      }
    }
  ]
}
