SET enable_indexscan = on;
SET enable_seqscan = off;
SELECT array_agg(id) AS approx_normalized_cosine
FROM (
	SELECT id
	FROM tq_metric_normalized_docs
	ORDER BY embedding <=> '[1,0]'
	LIMIT 3
) ranked;
