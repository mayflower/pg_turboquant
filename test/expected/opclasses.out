CREATE TABLE tq_halfvec_docs (
	id int4 PRIMARY KEY,
	embedding halfvec(4)
);
INSERT INTO tq_halfvec_docs (id, embedding) VALUES
	(1, '[1,0,0,0]'),
	(2, '[0,1,0,0]'),
	(3, '[0.70710678,0.70710678,0,0]');
CREATE INDEX tq_halfvec_docs_embedding_tq_idx
	ON tq_halfvec_docs
	USING turboquant (embedding tq_halfvec_cosine_ops)
	WITH (
		bits = 4,
		lists = 0,
		lanes = auto,
		transform = 'hadamard',
		normalized = true
	);
EXPLAIN (COSTS OFF)
SELECT id
FROM tq_halfvec_docs
ORDER BY embedding <=> '[1,0,0,0]'::halfvec(4)
LIMIT 1;
                                 QUERY PLAN                                 
----------------------------------------------------------------------------
 Limit
   ->  Index Scan using tq_halfvec_docs_embedding_tq_idx on tq_halfvec_docs
         Order By: (embedding <=> '[1,0,0,0]'::halfvec(4))
